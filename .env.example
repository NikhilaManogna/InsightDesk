LLM_PROVIDER=groq
LLM_TIMEOUT_SECONDS=45
LLM_MAX_RETRIES=2
LLM_TEMPERATURE=0
SQL_RETRY_COUNT=2
PROMPT_MAX_TABLES=6

GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Optional providers. Only set these if you switch LLM_PROVIDER.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# PostgreSQL is optional if you only want to use DuckDB.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=analytics
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# DuckDB file path. The app will create it if it does not exist.
DUCKDB_PATH=./cache/insightdesk.duckdb

QUERY_TIMEOUT_SECONDS=30
QUERY_LIMIT=1000
LOG_LEVEL=INFO
CACHE_TTL_SECONDS=900

MAX_VISUALIZATION_ROWS=5000
VISUALIZATION_SAMPLE_THRESHOLD=10000
CHART_CATEGORY_LIMIT=25
HISTOGRAM_BINS=30
MAX_KPIS=4

INSIGHT_MAX_ROWS_SENT=30
INSIGHT_VERBOSITY=concise
ANOMALY_SENSITIVITY=2.0
INSIGHT_MAX_KPIS=4
INSIGHT_TEMPERATURE=0.1
INSIGHT_MAX_TOKENS=700

SCHEMA_RAG_ENABLED=false
EMBEDDING_MODEL=all-MiniLM-L6-v2
BUSINESS_ALIASES=revenue=total_revenue revenue amount order_amount sales;customers=customers users customer_id user_id;sales=orders transactions revenue

REDIS_CACHE_ENABLED=false
REDIS_URL=redis://localhost:6379/0
GENERATED_SQL_CACHE_TTL_SECONDS=900

QUERY_HISTORY_PATH=./cache/query_history.jsonl
QUERY_HISTORY_LIMIT=200
